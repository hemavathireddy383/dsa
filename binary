# Binary search to find an employee ID in a sorted list

employee_ids = [1001, 1005, 1010, 1015, 1020, 1025]
target = 1015

low = 0
high = len(employee_ids) - 1
found = False

while low <= high:
    mid = (low + high) // 2

    if employee_ids[mid] == target:
        print("Employee found at index", mid)
        found = True
        break
    elif employee_ids[mid] < target:
        low = mid + 1
    else:
        high = mid - 1

if not found:
    print("Employee ID not found")
